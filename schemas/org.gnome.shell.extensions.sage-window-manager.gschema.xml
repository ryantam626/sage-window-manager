<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
    <schema id="org.gnome.shell.extensions.sage-window-manager" path="/org/gnome/shell/extensions/sage-window-manager/">
        <key name="sage-cycle-windows-forward" type="as">
            <default>["&lt;Super&gt;J"]</default>
            <summary>Cycle windows forward</summary>
            <description>Keybinding to cycle through windows in forward direction</description>
        </key>
        <key name="sage-cycle-windows-backward" type="as">
            <default>["&lt;Super&gt;K"]</default>
            <summary>Cycle windows backward</summary>
            <description>Keybinding to cycle through windows in backward direction</description>
        </key>
        <key name="sage-move-to-workspace-1" type="as">
            <default><![CDATA[['<Shift><Super>1']]]></default>
            <summary>Move window to workspace 1</summary>
        </key>
        <key name="sage-move-to-workspace-2" type="as">
            <default><![CDATA[['<Shift><Super>2']]]></default>
            <summary>Move window to workspace 2</summary>
        </key>
        <key name="sage-move-to-workspace-3" type="as">
            <default><![CDATA[['<Shift><Super>3']]]></default>
            <summary>Move window to workspace 3</summary>
        </key>
        <key name="sage-move-to-workspace-4" type="as">
            <default><![CDATA[['<Shift><Super>4']]]></default>
            <summary>Move window to workspace 4</summary>
        </key>
        <key name="sage-move-to-workspace-5" type="as">
            <default><![CDATA[['<Shift><Super>5']]]></default>
            <summary>Move window to workspace 5</summary>
        </key>
        <key name="sage-send-window-to-screen-1" type="as">
            <default><![CDATA[['<Shift><Super>I']]]></default>
            <summary>Send window to screen 1</summary>
        </key>
        <key name="sage-send-window-to-screen-2" type="as">
            <default><![CDATA[['<Shift><Super>U']]]></default>
            <summary>Send window to screen 2</summary>
        </key>
        <key name="sage-send-window-to-screen-3" type="as">
            <default><![CDATA[['<Shift><Super>O']]]></default>
            <summary>Send window to screen 3</summary>
        </key>
        <key name="sage-send-window-to-screen-4" type="as">
            <default><![CDATA[['<Shift><Super>8']]]></default>
            <summary>Send window to screen 4</summary>
        </key>
        <key name="sage-focus-screen-1" type="as">
            <default><![CDATA[['<Super>I']]]></default>
            <summary>Move focus to screen 1</summary>
        </key>
        <key name="sage-focus-screen-2" type="as">
            <default><![CDATA[['<Super>U']]]></default>
            <summary>Move focus to screen 2</summary>
        </key>
        <key name="sage-focus-screen-3" type="as">
            <default><![CDATA[['<Super>O']]]></default>
            <summary>Move focus to screen 3</summary>
        </key>
        <key name="sage-focus-screen-4" type="as">
            <default><![CDATA[['<Super>8']]]></default>
            <summary>Move focus to screen 4</summary>
        </key>
        <key name="screen-order" type="ai">
            <default>[1, 0, 2, 3]</default>
            <summary>Logical to physical monitor order mapping</summary>
            <description>
                Maps logical screen shortcuts (1-4) to physical monitor indexes.
                Example: [1, 0, 2, 3] swaps the first two logical screens.
            </description>
        </key>
    </schema>
</schemalist>
